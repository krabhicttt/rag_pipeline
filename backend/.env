# =====================================================
#  RAG Chat Backend — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# =====================================================

# ----- Postgres (pgvector) -----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag_db
POSTGRES_USER=rag_db_usr
POSTGRES_PASSWORD=rag_db_usr

# ----- Ollama -----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2          # model used for answering questions
OLLAMA_EMBED_MODEL=nomic-embed-text # model used for generating embeddings

# ----- RAG Settings -----
CHUNK_SIZE=512          # characters per chunk
CHUNK_OVERLAP=64        # overlap between consecutive chunks
TOP_K_RESULTS=5         # number of chunks to retrieve per query

# ----- API Server -----
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,*
